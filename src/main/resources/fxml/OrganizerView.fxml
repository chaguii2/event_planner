<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.OrganizerController">

    <top>
        <VBox style="-fx-background-color: #27ae60;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets top="15" right="20" bottom="15" left="20"/>
                </padding>
                <Label text="📅 Event Planner" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="welcomeLabel" style="-fx-text-fill: white;"/>
                <Button text="Logout" onAction="#handleLogout"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">
            <padding>
                <Insets top="50" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Organizer Dashboard" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
            <Label text="This is the organizer area. More features coming soon..."/>
        </VBox>
    </center>
</BorderPane>