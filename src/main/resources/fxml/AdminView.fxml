<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.AdminController">

    <top>
        <VBox style="-fx-background-color: #3498db;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets top="15" right="20" bottom="15" left="20"/>
                </padding>
                <Label text="📅 Event Planner" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="welcomeLabel" style="-fx-text-fill: white;"/>
                <Button text="👤 Mon Profil" onAction="#handleProfile"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5;"/>
                <Button text="Logout" onAction="#handleLogout"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Filter Section -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Filter by Role:"/>
                <ComboBox fx:id="filterComboBox" prefWidth="150"/>
                <Button text="Apply Filter" onAction="#handleFilter"/>
                <Button text="Clear Filter" onAction="#handleFilter"/>
            </HBox>

            <!-- User Table -->
            <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="150"/>
                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="200"/>
                    <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="120"/>
                    <TableColumn fx:id="roleColumn" text="Role" prefWidth="100"/>
                </columns>
            </TableView>

            <!-- Edit Section -->
            <TitledPane text="Edit User" expanded="false">
                <content>
                    <VBox spacing="10">
                        <GridPane hgap="10" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints halignment="RIGHT" minWidth="80"/>
                                <ColumnConstraints minWidth="200"/>
                            </columnConstraints>

                            <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Phone:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="phoneField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Role:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="roleComboBox" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="200"/>
                        </GridPane>

                        <HBox spacing="10" alignment="CENTER">
                            <Button text="Update" onAction="#handleUpdate" prefWidth="100"/>
                            <Button text="Delete" onAction="#handleDelete" prefWidth="100"/>
                            <Button text="Clear" onAction="#handleClear" prefWidth="100"/>
                        </HBox>
                    </VBox>
                </content>
            </TitledPane>
        </VBox>
    </center>
</BorderPane>