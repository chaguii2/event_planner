<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.ProfileController"
      alignment="CENTER" style="-fx-background-color: #f5f5f5;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="👤 Mon Profil" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
        <font>
            <Font size="24"/>
        </font>
    </Label>

    <Separator prefWidth="400"/>

    <GridPane hgap="15" vgap="15" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="100"/>
            <ColumnConstraints minWidth="250"/>
        </columnConstraints>

        <Label text="Nom:" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"
                   style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7;"/>

        <Label text="Email:" style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="1"
                   style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7;"/>

        <Label text="Téléphone:" style="-fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="phoneField" GridPane.rowIndex="2" GridPane.columnIndex="1"
                   style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7;"/>

        <Label text="Rôle:" style="-fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Label fx:id="roleLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"
               style="-fx-font-weight: bold; -fx-text-fill: #3498db;"/>

        <Separator GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.columnSpan="2"
                   prefWidth="350" style="-fx-background-color: #bdc3c7;"/>

        <Label text="Nouveau mot de passe:" style="-fx-font-weight: bold;" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <PasswordField fx:id="newPasswordField" GridPane.rowIndex="5" GridPane.columnIndex="1"
                       promptText="Laisser vide pour ne pas changer"
                       style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7;"/>

        <Label text="Confirmer:" style="-fx-font-weight: bold;" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <PasswordField fx:id="confirmPasswordField" GridPane.rowIndex="6" GridPane.columnIndex="1"
                       promptText="Répéter le nouveau mot de passe"
                       style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #bdc3c7;"/>
    </GridPane>

    <Separator prefWidth="400"/>

    <HBox spacing="15" alignment="CENTER">
        <Button text="💾 Enregistrer" onAction="#handleSave"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"
                prefWidth="120"/>
        <Button text="❌ Annuler" onAction="#handleCancel"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 5;"
                prefWidth="120"/>
    </HBox>
</VBox>